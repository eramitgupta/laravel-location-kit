{
    "name": "erag/laravel-location-kit",
    "description": "Laravel data-only countries, states, cities, currencies, timezones, and dial codes for helpers and Blade.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LaravelLocationKit\\": "src/"
        },
        "files": [
            "src/Support/Helpers.php"
        ]
    },
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelLocationKit\\LocationKitServiceProvider"
            ],
            "aliases": {
                "LocationKit": "LaravelLocationKit\\Facades\\LocationKit"
            }
        }
    },
    "scripts": {
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
